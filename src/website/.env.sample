# Server-side variables (preferred names used by the app)
API_URL=
API_TOKEN=
OPENCAGE_API_KEY=
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=
GOOGLE_SITE_VERIFICATION=

# Client-side variables (these need NEXT_PUBLIC_ prefix)
# Comma-separated site URLs. The first entry is used as the canonical base.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Which Clean Air Forum edition's submissions the /faces-of-clean-air page shows.
NEXT_PUBLIC_CLEAN_AIR_FORUM_EVENT_ID=clean-air-forum