# Copy to .env.e2e (gitignored) and fill in for local e2e runs.
# Not required to run `public` project tests (e.g. e2e/tests/public/login.spec.ts).
# Required for the `setup` project and any authenticated test in `chromium`.

# Where Playwright's webServer + tests point. Defaults to http://localhost:3000.
PLAYWRIGHT_BASE_URL=http://localhost:3000

# A real, seeded test account. Should belong to at least two organizations
# (personal "airqo" + one external org) once org-switching tests are added.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Leave NEXT_PUBLIC_HCAPTCHA_SITE_KEY unset in .env.local while running e2e —
# isHCaptchaEnabled() (lib/envConstants.ts) only turns the widget on when a site
# key is present, and the auth setup script can't solve a captcha.
