# ============================================
# AirQo E2E Test Configuration
# ============================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# All variables below are REQUIRED for tests to run.

# --------------------------------------------
# APP URL
# --------------------------------------------
# Where your app is running locally.
# After running "npm run dev", check the terminal output.
# Usually: http://localhost:3000
BASE_URL=http://localhost:3000

# --------------------------------------------
# BROWSER
# --------------------------------------------
# Which browser Selenium uses to run tests.
# Options: chrome, firefox, edge
BROWSER=chrome

# --------------------------------------------
# HEADLESS MODE
# --------------------------------------------
# true  = browser runs in background (no window visible) — faster, good for CI
# false = browser window opens so you can watch tests run — useful for debugging
HEADLESS=true

# --------------------------------------------
# TIMEOUTS (in seconds)
# --------------------------------------------
# How long to wait for elements to appear before failing
IMPLICIT_WAIT=10

# How long to wait for a page to fully load
PAGE_LOAD_TIMEOUT=30

# --------------------------------------------
# TEST USER CREDENTIALS
# --------------------------------------------
# You need a real account that exists in your AirQo backend.
# If you don't have one, register at: http://localhost:3000/user/register
# then use those credentials here.
#
# Example:
#   TEST_USER_EMAIL=john@gmail.com
#   TEST_USER_PASSWORD=MySecurePass123!
TEST_USER_EMAIL=your-real-email@example.com
TEST_USER_PASSWORD=your-real-password

# --------------------------------------------
# TEST ORGANIZATION SLUG
# --------------------------------------------
# The URL slug of an organization you belong to.
# After logging in, go to your org dashboard.
# If the URL is http://localhost:3000/org/my-team/dashboard
# then the slug is "my-team".
#
# Example:
#   TEST_ORG_SLUG=my-team
TEST_ORG_SLUG=your-org-slug
