# Vertex template environment
#
# The template runs in mock mode by default and requires no credentials.
# Copy this file to .env.local and adjust values as needed:
#   cp .env.example .env.local

# App environment label: development | staging | production
NEXT_PUBLIC_ENV=development

# Optional: Mapbox access token. Only needed when map.tileProvider
# is set to "mapbox" in vertex.config.ts.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
