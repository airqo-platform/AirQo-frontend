  "scripts": {
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "start": "serve -s build",
    "prestart": "npm install -g serve",
    "dev": "cross-env REACT_APP_ENV=development react-scripts start",
    "stage": "cross-env REACT_APP_BASE_URL=https://staging-platform.airqo.net/api/v1/ react-scripts start",
    "prod": "cross-env REACT_APP_BASE_URL=https://platform.airqo.net/api/v1/ react-scripts start",
    "build": "react-scripts --max_old_space_size=4096 build",
    "SMD-build-mac": "GENERATE_SOURCEMAP=false react-scripts build",
    "SMD-build-pc": "set GENERATE_SOURCEMAP=false&&react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "create-env": "printenv > .env"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not chrome < 51",
      "not safari < 10"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "css-loader": "^7.1.2",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.8",
