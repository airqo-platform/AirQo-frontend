    "prettier": "^3.3.3",
    "redux-mock-store": "^1.5.4"
  },
  "jest": {
    "snapshotSerializers": [
      "enzyme-to-json/serializer"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageReporters": [
      "clover",
      "json",
      "lcov",
      "text"
    ],
    "setupFilesAfterEnv": [
      "/setupTests.js"
    ]
  }
